rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() { return hasRole('ADMIN'); }
    function isCoordinator() { return hasRole('COORDINATOR'); }
    function isMentor() { return hasRole('MENTOR'); }
    function isInnovator() { return hasRole('INNOVATOR'); }
    function isFunder() { return hasRole('FUNDER'); }
    function isManager() { return hasRole('MANAGER'); }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // --- Collections ---

    match /users/{userId} {
      // Users can read any profile (for directory/collaboration) but only edit their own (limited)
      // Admins and Managers can edit all
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isAdmin() || isManager() || (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL']));
    }

    match /programmes/{programmeId} {
      // Everyone can see programmes/challenges
      // Only Admin, Manager, Coordinator can manage
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager() || isCoordinator();
    }

    match /innovations/{innovationId} {
      // Innovators see their own
      // Mentors see assigned
      // Admins, Managers, Coordinators see all
      // Funders see all (read-only)
      allow read: if isAdmin() || isManager() || isCoordinator() || isFunder() || 
                    (isInnovator() && resource.data.innovatorId == request.auth.uid) ||
                    (isMentor() && resource.data.mentorId == request.auth.uid);
      
      // Only Admin, Coordinator, or the Innovator themselves can create/update
      allow create: if isAdmin() || isCoordinator() || isInnovator();
      allow update: if isAdmin() || isCoordinator() || 
                      (isInnovator() && resource.data.innovatorId == request.auth.uid) ||
                      (isMentor() && resource.data.mentorId == request.auth.uid);
    }

    match /sessions/{sessionId} {
      // Mentors and their assigned innovators can see sessions
      // Admins, Coordinators see all
      allow read: if isAdmin() || isCoordinator() || isManager() ||
                    resource.data.mentorId == request.auth.uid ||
                    resource.data.innovatorId == request.auth.uid;
      
      allow write: if isAdmin() || isCoordinator() || isMentor();
    }

    match /kpis/{kpiId} {
      // Everyone can see impact data
      // Only Admin, Manager, Coordinator can update
      allow read: if isSignedIn();
      allow write: if isAdmin() || isManager() || isCoordinator();
    }
  }
}
